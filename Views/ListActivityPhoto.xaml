<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.ListActivityPhoto"
             xmlns:localF="clr-namespace:MauiApp1"
             Title="Все деятельности"
             Shell.BackgroundColor="Red"
             Shell.TitleColor="White">

    <VerticalStackLayout>
        <Label 
        Text="Деятельности клиента"
        VerticalOptions="Center" 
        HorizontalOptions="Center"  />
        <Button Text="Деятельносить № 1" Clicked="OnTakeFirstActivityButtonClicked" Margin="10" BackgroundColor="#ff0000" FontAttributes="Bold"  />
        <Button Text="Деятельносить № 2" Clicked="OnTakeSecondActivityButtonClicked" Margin="10" BackgroundColor="#ff0000" FontAttributes="Bold"  />
        <Button Text="Деятельносить № 3" Clicked="OnTakeThirdActivityButtonClicked" Margin="10" BackgroundColor="#ff0000" FontAttributes="Bold"  />
    </VerticalStackLayout>

</ContentPage>