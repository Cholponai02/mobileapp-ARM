<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class=" MauiApp1.Views.PoruchPhoto"
             xmlns:localF="clr-namespace: MauiApp1"
             Title="PoruchPhoto">
    <VerticalStackLayout>
        <Label Text="Фото поручителя " VerticalOptions="Center" HorizontalOptions="Center" 
            FontAttributes="Bold" Margin="0,15,0,0" />

        <Button Text="Сделать фото поручителя с паспортом в руке" Clicked="OnTakePhotoSelfieButtonClicked" Margin="20" BackgroundColor="#ff0000" FontAttributes="Bold"/>
        <Button Text="Сделать фото паспорта с лицевой стороны" Clicked="OnTakePhotoFrontPassButtonClicked" Margin="20" BackgroundColor="#ff0000" FontAttributes="Bold"/>
        <Button Text="Сделать фото паспорта с обратной стороны" Clicked="OnTakePhotoBackPassButtonClicked" Margin="20" BackgroundColor="#ff0000" FontAttributes="Bold"/>
        
        <ActivityIndicator x:Name="loadingIndicator"
           IsRunning="False" IsVisible="False" HorizontalOptions="Center" VerticalOptions="Center" />
        
    </VerticalStackLayout>
</ContentPage>